{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "postgres": {
            "type": "object",
            "properties": {
                "databases": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "host": {
                                "type": "string"
                            },
                            "name": {
                                "type": "string"
                            },
                            "port": {
                                "type": "integer"
                            },
                            "pwd": {
                                "type": "string"
                            },
                            "sidecar-name": {
                                "type": "string"
                            },
                            "user": {
                                "type": "string"
                            }
                        }
                    }
                },
                "enabled": {
                    "type": "boolean"
                },
                "image": {
                    "type": "string"
                }
            }
        }
    }
}
