{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "argo-events": {
            "type": "object",
            "properties": {
                "crds": {
                    "type": "object",
                    "properties": {
                        "install": {
                            "type": "boolean"
                        }
                    }
                },
                "enabled": {
                    "type": "boolean"
                }
            }
        },
        "argoEvents": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "eventBus": {
                    "type": "object",
                    "properties": {
                        "auth": {
                            "type": "string"
                        },
                        "create": {
                            "type": "boolean"
                        },
                        "replicas": {
                            "type": "integer"
                        }
                    }
                },
                "eventBusName": {
                    "type": "string"
                },
                "eventSource": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "serviceAccount": {
                            "type": "object",
                            "properties": {
                                "create": {
                                    "type": "boolean"
                                },
                                "name": {
                                    "type": "string"
                                }
                            }
                        },
                        "watchNamespace": {
                            "type": "string"
                        }
                    }
                },
                "job": {
                    "type": "object",
                    "properties": {
                        "generateNameSuffix": {
                            "type": "string"
                        }
                    }
                },
                "sensor": {
                    "type": "object",
                    "properties": {
                        "serviceAccount": {
                            "type": "object",
                            "properties": {
                                "create": {
                                    "type": "boolean"
                                },
                                "name": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "sidecarInjectAnnotation": {
                    "type": "string"
                },
                "triggerSetupJob": {
                    "type": "boolean"
                }
            }
        },
        "postgres": {
            "type": "object",
            "properties": {
                "databases": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "host": {
                                "type": "string"
                            },
                            "name": {
                                "type": "string"
                            },
                            "namespace": {
                                "type": "string"
                            },
                            "port": {
                                "type": "integer"
                            },
                            "pwd": {
                                "type": "string"
                            },
                            "sidecar-name": {
                                "type": "string"
                            },
                            "user": {
                                "type": "string"
                            }
                        }
                    }
                },
                "enabled": {
                    "type": "boolean"
                },
                "image": {
                    "type": "string"
                }
            }
        }
    }
}
